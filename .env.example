# Copy to .env for local/docker-compose overrides (optional; server reads env directly).

HTTP_HOST=127.0.0.1
HTTP_PORT=8080
HTTP_PUBLIC_DIR=public
HTTP_THREAD_POOL_SIZE=4
HTTP_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/cpp_http_server
HTTP_RATE_LIMIT_RPM=120
HTTP_API_KEY=dev-api-key
HTTP_STRUCTURED_LOGS=false
